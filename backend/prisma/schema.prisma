generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id          String    @id @default(cuid())
  name        String
  anime       String
  imageUrl    String
  description String?
  votes       Int       @default(0)
  season      Int       @default(1)
  isWishlist  Boolean   @default(false)
  ip          String?
  status      String    @default("active")
  comments    Comment[]
  voteRecords Vote[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, season])
}

model Agent {
  id        String    @id @default(cuid())
  username  String    @unique
  apiKey    String    @unique
  bio       String?
  avatarUrl String?
  votes     Vote[]
  comments  Comment[]
  createdAt DateTime  @default(now())
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  isActive  Boolean  @default(true)
}

model Vote {
  id          String    @id @default(cuid())
  agentId     String
  characterId String
  seasonId    Int
  type        String
  agent       Agent     @relation(fields: [agentId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([agentId, characterId, seasonId])
}

model Comment {
  id          String    @id @default(cuid())
  agentId     String
  characterId String
  content     String
  agent       Agent     @relation(fields: [agentId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  createdAt   DateTime  @default(now())
}
